# ──────────────────────────────────────────────
# Copy this file to .env.local and fill in values
# NEVER commit .env.local to git
# ──────────────────────────────────────────────

# Neon Database (get from Neon dashboard → Connection string)
DATABASE_URL=

# NextAuth / Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=

# Google OAuth (console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Discord OAuth (discord.com/developers)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Resend email (resend.com → API Keys)
RESEND_API_KEY=
EMAIL_FROM=noreply@yourdomain.com

# Vercel Blob (automatically injected by Vercel, set manually for local dev)
BLOB_READ_WRITE_TOKEN=
